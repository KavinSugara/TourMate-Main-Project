              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "put": {
        "tags": [
          "Guides"
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Guide"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Guide"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Guide"
              }
            }
          }
